#!/bin/bash
# Pre-removal script for open-sesame
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop and disable user services for the invoking user.
        # This runs as root during dpkg, so we can't target the user's
        # systemd instance directly. Users must stop services manually
        # or they will fail gracefully on next login.
        echo "NOTE: Run these commands to stop Open Sesame services:"
        echo "  systemctl --user stop open-sesame.target"
        echo "  systemctl --user disable open-sesame.target"
        #DEBHELPER#
        ;;
esac

exit 0
