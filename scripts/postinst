#!/bin/bash
# Post-installation script for open-sesame
set -e

case "$1" in
    configure)
        echo ""
        echo "open-sesame installed successfully!"
        echo ""
        echo "To enable the daemon suite:"
        echo "  systemctl --user daemon-reload"
        echo "  systemctl --user enable --now open-sesame.target"
        echo ""
        echo "To initialize configuration:"
        echo "  sesame init"
        echo ""
        echo "To setup the keybinding:"
        echo "  sesame setup-keybinding"
        echo ""
        echo "Configuration: ~/.config/pds/config.toml"
        echo ""
        echo "NOTE: daemon-input requires 'input' group membership for keyboard capture."
        echo "  sudo usermod -aG input \$USER"
        echo "  (logout and login required)"
        echo ""
        #DEBHELPER#
        ;;
esac

exit 0
