#!/bin/bash
# Post-installation script for open-sesame-desktop
set -e

active_user_uids() {
    systemctl list-units 'user@*' --legend=no 2>/dev/null \
        | sed -n 's/.*user@\([0-9]\+\)\.service.*/\1/p'
}

case "$1" in
    configure)
        # 1. Enable globally.
        systemctl --global enable \
            open-sesame-wm.service \
            open-sesame-clipboard.service \
            open-sesame-input.service \
            open-sesame-desktop.target \
            2>/dev/null || true

        # 2. Reload all active user managers.
        systemctl reload 'user@*.service' 2>/dev/null || true

        # 3. Start desktop services for all active users.
        for uid in $(active_user_uids); do
            SYSTEMD_BUS_TIMEOUT=25s systemctl --user -M "$uid@" \
                restart open-sesame-wm.service 2>/dev/null || true
            SYSTEMD_BUS_TIMEOUT=25s systemctl --user -M "$uid@" \
                restart open-sesame-clipboard.service 2>/dev/null || true
            SYSTEMD_BUS_TIMEOUT=25s systemctl --user -M "$uid@" \
                restart open-sesame-input.service 2>/dev/null || true
        done

        echo ""
        echo "open-sesame-desktop installed!"
        echo "  Desktop daemons enabled: window manager, clipboard, input"
        echo ""
        echo "NOTE: daemon-input requires 'input' group membership for keyboard capture."
        echo "  sudo usermod -aG input \$USER"
        echo "  (logout and login required)"
        echo ""
        #DEBHELPER#
        ;;
esac

exit 0
